# Accord Protocol Environment Variables
# Copy this file to .env (root) and frontend/.env.local

# ── Contract ─────────────────────────────────────────────────────────────────
# The deployed Soroban contract ID (fill in after running scripts/deploy.sh)
VITE_CONTRACT_ADDRESS=

# ── Network ──────────────────────────────────────────────────────────────────
# Testnet RPC endpoint
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Testnet passphrase (do not change for testnet)
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Local Dev (optional) ─────────────────────────────────────────────────────
# Set these when running docker compose up for a local Soroban node
# VITE_SOROBAN_RPC_URL=http://localhost:8000
# VITE_NETWORK_PASSPHRASE=Standalone Network ; February 2017
